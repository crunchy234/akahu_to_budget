{
  "name": "Akahu to Budget",
  "version": "1.0.0",
  "slug": "akahu_to_budget",
  "description": "Sync bank transactions from Akahu to Actual Budget and YNAB on a schedule",
  "url": "https://github.com/corrin/akahu_to_budget",
  "arch": ["amd64", "aarch64", "armv7"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "map": ["share:rw"],
  "options": {
    "AKAHU_USER_TOKEN": "",
    "AKAHU_APP_TOKEN": "",
    "RUN_SYNC_TO_AB": true,
    "ACTUAL_SERVER_URL": "",
    "ACTUAL_PASSWORD": "",
    "ACTUAL_ENCRYPTION_KEY": "",
    "ACTUAL_SYNC_ID": "",
    "RUN_SYNC_TO_YNAB": false,
    "YNAB_BEARER_TOKEN": "",
    "YNAB_BUDGET_ID": "",
    "FORCE_REFRESH": false,
    "DEBUG_SYNC": false,
    "sync_interval": 86400
  },
  "schema": {
    "AKAHU_USER_TOKEN": "str",
    "AKAHU_APP_TOKEN": "str",
    "RUN_SYNC_TO_AB": "bool",
    "ACTUAL_SERVER_URL": "str",
    "ACTUAL_PASSWORD": "password",
    "ACTUAL_ENCRYPTION_KEY": "password",
    "ACTUAL_SYNC_ID": "str",
    "RUN_SYNC_TO_YNAB": "bool",
    "YNAB_BEARER_TOKEN": "password?",
    "YNAB_BUDGET_ID": "str?",
    "FORCE_REFRESH": "bool?",
    "DEBUG_SYNC": "bool?",
    "AKAHU_PUBLIC_KEY": "str?",
    "OPENAI_API_KEY": "password?",
    "OPENAI_BASE_URL": "str?",
    "OPENAI_MODEL": "str?",
    "sync_interval": "int(60,86400)"
  }
}
