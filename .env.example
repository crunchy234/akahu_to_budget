# Force refresh deletes our copy of your actual budget data next run, which can be helpful if we somehow get out of sync
FORCE_REFRESH=false

FLASK_ENV=development

AKAHU_APP_TOKEN= # app_token_clp - see in my.akahu.nz/developers
AKAHU_PUBLIC_KEY= # Dont worry for now - future state
AKAHU_USER_TOKEN= # Secret from User token

# Set to false if you don't have an Actual Budget account, or otherwise want to disable updating AB
RUN_SYNC_TO_AB=true
ACTUAL_SERVER_URL=https://certain-myna.pikapod.net
ACTUAL_PASSWORD= # Password to access all your actual budgets
ACTUAL_ENCRYPTION_KEY= # Encryption key for this specific budget
ACTUAL_SYNC_ID= # Under advanced settings - next to budget ID

# Set to false if you don't have a YNAB account, or otherwise want to disable updating YNAB
RUN_SYNC_TO_YNAB=true
YNAB_BEARER_TOKEN= # QQw-key from YNAB
YNAB_BUDGET_ID= # From the YNAB URL

# Set to true if you want to sync to a self-hosted Sure Finance instance.
# Leave unset / false otherwise. Defaults to false to avoid breaking existing setups.
RUN_SYNC_TO_SURE=false
SURE_API_TOKEN= # API token from your Sure Finance instance
SURE_API_URL= # Optional: defaults to http://127.0.0.1:8084/api/v1/transactions

# AI Config
OPENAI_API_KEY= # sk- key from OpenAI for account matching
OPENAI_BASE_URL= # For users running ollama serve: http://localhost:11434/v1 or similar
OPENAI_MODEL= # defaults to gpt-5.2

# Set to true for additional sync-related debug logging
DEBUG_SYNC=false
